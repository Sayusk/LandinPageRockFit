# =============================================================
# RockFit Brasil — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite valores reais. Adicione .env.local ao .gitignore.
# =============================================================

# ---- Supabase -----------------------------------------------
# URL do seu projeto Supabase (Settings > API)
VITE_SUPABASE_URL=

# Chave anônima (pública) — pode ir para o frontend
VITE_SUPABASE_ANON_KEY=

# Chave de serviço (SECRETA) — somente backend/serverless
SUPABASE_SERVICE_ROLE_KEY=

# Alias sem VITE para uso nas funções serverless
SUPABASE_URL=

# ---- Mercado Pago -------------------------------------------
# Chave pública (pode ir para o frontend — sem VITE_ não vai)
VITE_MERCADO_PAGO_PUBLIC_KEY=

# Access Token (SECRETO) — somente backend/serverless
MERCADO_PAGO_ACCESS_TOKEN=

# Secret para verificação de assinatura do webhook
MERCADO_PAGO_WEBHOOK_SECRET=

# ---- Aplicação ----------------------------------------------
# URL pública do seu deploy (ex: https://rockfitbrasil.vercel.app)
VITE_APP_URL=

# ---- Admin --------------------------------------------------
# Token simples para acessar /admin/alunos
# Troque por autenticação real em produção
VITE_ADMIN_ACCESS_TOKEN=
